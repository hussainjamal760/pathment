# ───────────────────────── Pathment server — environment ─────────────────────────
# Copy to `.env` and fill in. For production deploy details see DEPLOY.md.

# ── Core ──
NODE_ENV=production
PORT=5000
# Domain Caddy serves the API on (used by docker-compose + Caddyfile). e.g. api.pathment.me
API_DOMAIN=api.yourdomain.com
# Comma-separated allowed origins for CORS + Socket.IO (your Vercel frontend URL(s)).
# Supports * wildcards, e.g. https://*.vercel.app
CLIENT_URL=https://app.yourdomain.com

# ── Database (DigitalOcean managed Postgres) ──
# MUST include ?sslmode=require for DO managed databases.
DATABASE_URL=postgres://USER:PASSWORD@HOST:25060/DBNAME?sslmode=require

# ── Auth (JWT) — generate long random strings: `openssl rand -hex 48` ──
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Image uploads (Cloudinary) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Max upload size in bytes (optional)
MAX_FILE_SIZE=5242880

# ── AI provider (Groq / OpenAI-compatible) ──
AI_API_KEY=
AI_PROVIDER=groq
AI_MODEL=llama-3.1-8b-instant
AI_BASE_URL=https://api.groq.com/openai/v1
# Encrypts users' bring-your-own AI keys at rest — generate: `openssl rand -hex 32`
AI_ENCRYPTION_KEY=
# Free-tier-safe roadmap generation limits
AI_ROADMAP_MAX_TOTAL_TOKENS=5800
AI_ROADMAP_OUTPUT_TOKENS=1200
AI_ROADMAP_MIN_OUTPUT_TOKENS=500
AI_ROADMAP_CHUNK_WEEKS=2

# ── Email (Resend) + the DB-backed email queue ──
RESEND_API_KEY=
RESEND_FROM=Pathment <noreply@pathment.me>
RESEND_REPLY_TO=support@pathment.me
# Verifies the Resend bounce/complaint webhook at POST /webhooks/resend
RESEND_WEBHOOK_SECRET=
# Notification email gating / limits (free-tier-safe defaults)
EMAIL_NOTIFICATION_EMAILS_ENABLED=false
EMAIL_DISABLED_EVENTS=
EMAIL_DAILY_LIMIT=100
EMAIL_DAILY_LIMIT_PER_RECIPIENT=20
# Email worker tuning (optional)
EMAIL_WORKER_POLL_MS=10000
EMAIL_WORKER_BATCH=20
EMAIL_MAX_ATTEMPTS=5

# ── Registration invites ──
REGISTRATION_INVITE_EXPIRY_HOURS=72

# ── Rate limiting (optional) ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# ── Background schedulers (optional toggles / timing) ──
# NOTIFICATION_SCHEDULER_DISABLED=false
# WEEKLY_REPORT_DAY=1
# WEEKLY_REPORT_HOUR_UTC=8
# COMMUNITY_STANDUP_DAY=1
# COMMUNITY_STANDUP_HOUR_UTC=9
